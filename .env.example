# ── 数据源 ──
# Tushare API（A股日线/财务/指数主源）。申请见 https://tushare.pro
# 代理站地址可选；留空则用官方 https://api.tushare.pro
TUSHARE_TOKEN=
TUSHARE_API_URL=https://ts.gyzcloud.top/api

# ── 服务器管理 Key（受保护接口鉴权，空=开发模式免认证）──
API_KEY=

# ── LLM（AI 策略/智能体辩论，空=该功能不可用，不影响其他）──
LLM_BASE_URL=
LLM_API_KEY=
LLM_QUICK_MODEL=deepseek-chat
LLM_DEEP_MODEL=deepseek-reasoner
LLM_TEMPERATURE=0.1

# ── 通达信 MCP（可选补充源，空=自动降级）──
TDX_API_KEY=
TDX_MCP_URL=https://mcp.tdx.com.cn:3001/mcp
TDX_MCP_STOCK_LIST_TOOL=
TDX_MCP_WENDA_TOOL=tdx_wenda_quotes
TDX_MCP_TIMEOUT=15

# ── 调试（设置后异常返回完整堆栈，否则脱敏）──
# DEBUG=1
